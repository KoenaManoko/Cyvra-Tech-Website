@{
    ViewData["Title"] = "Cyvra Tech Solutions";
}

<header>
    <nav class="navbar">
        <div class="logo">
            <img src="~/images/cyvra-logo.png" alt="Cyvra Tech Logo" class="logo-img" />
            <span>Cyvra Tech Solutions</span>
        </div>

        <ul class="nav-links">
            <li><a href="#home">Home</a></li>
            <li><a href="#services">Services</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>
</header>

<section id="home" class="hero">
    <div class="hero-content">
        <h1>Empowering Businesses Through Technology</h1>
        <p>Cyvra Tech Solutions provides innovative website development, software development, IT consulting, and tech support services to help your business grow in the digital world.</p>

        <div class="hero-buttons">
            <a href="#services" class="btn btn-primary">Our Services</a>
            <a href="#contact" class="btn btn-secondary">Get in Touch</a>
        </div>
    </div>
</section>

<section id="services" class="services">
    <div class="container">
        <h2>Our Services</h2>

        <div class="services-grid">
            <div class="service-card">
                <h3>Website Development</h3>
                <p>Modern, responsive, and professional websites tailored to your business needs.</p>
            </div>

            <div class="service-card">
                <h3>Software Development</h3>
                <p>Custom software solutions designed to improve business efficiency and productivity.</p>
            </div>

            <div class="service-card">
                <h3>IT Consulting</h3>
                <p>Expert guidance on technology strategies and digital transformation.</p>
            </div>

            <div class="service-card">
                <h3>Tech Support</h3>
                <p>Reliable maintenance and support services to keep your systems running smoothly.</p>
            </div>
        </div>
    </div>
</section>
<section id="about"class="about-premium">
    <div class="about-container">
        <div class="about-image-card">
            <img src="~/images/koena-professional.jpg" alt="Koena Manoko" class="about-image" />
            <div class="about-name-card">
                <h3>Koena Manoko</h3>
                <p>Founder &amp; CEO</p>
            </div>
        </div>

        <div class="about-text-content">
            <span class="about-label">ABOUT CYVRA</span>
            <h2>Built by someone who’d rather solve the problem than sell you a buzzword.</h2>
            <p>
                Cyvra Tech Solutions is a South African-based information technology company specialising in modern digital solutions for businesses.
            </p>
            <p>
                Founded by Koena Manoko, the company focuses on building reliable, scalable, and efficient systems that help organisations grow in the digital age.
            </p>
            <blockquote>
                “Our job is to make technology disappear into the background, so your business just works.”
            </blockquote>
        </div>
    </div>
</section>

<section id="contact" class="contact">
    <div class="container">
        <h2>Contact Us</h2>

        <form class="contact-form">
            <input type="text" placeholder="Your Name" required />
            <input type="email" placeholder="Your Email" required />
            <textarea placeholder="Your Message" rows="5" required></textarea>
            <button type="submit" class="btn btn-primary">Send Message</button>
        </form>
    </div>
</section>

<footer>
    <div class="container footer-content">
        <p>&copy; @DateTime.Now.Year Cyvra Tech Solutions. All rights reserved.Website Live</p>
    </div>
</footer>

